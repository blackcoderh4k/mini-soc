# Virtual environment
.venv/
venv/
env/

# Python caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Pytest / Coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Type checking
.mypy_cache/

# IDE
.vscode/
.idea/

